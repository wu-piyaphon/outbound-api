ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # or https://api.alpaca.markets for live
DATABASE_URL=postgres://user:password@host:5432/dbname
BOT_API_KEY=your_secret_bot_api_key

# Optional — trading parameters (shown with defaults)
PORT=8080
BOT_AUTOSTART=true
RISK_PER_TRADE_PCT=0.01         # fraction of budget risked per trade (1%)
ATR_RISK_MULTIPLIER=2.0         # ATR × multiplier = stop-loss distance
TAKE_PROFIT_MULTIPLIER=3.0      # ATR × multiplier = take-profit distance

# Optional — fee parameters (shown with defaults matching Alpaca standard rates)
COMMISSION_FEE_PCT=0.0005       # 0.05% commission on notional per fill
FX_FEE_PCT=0.0001               # 0.01% FX conversion fee amortised per fill
